rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: notes
    // Document ID: {noteId}
    // Fields:
    //   - id: string (required, max 100 chars)
    //   - userId: string (required, immutable, max 100 chars)
    //   - title: string (required, max 500 chars)
    //   - content: string (required, max 100000 chars)
    //   - isPinned: boolean (required)
    //   - deadline: timestamp (optional)
    //   - createdAt: timestamp (required, immutable)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - email: string (required, email format)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }
    
    function uidUnchanged() {
      return !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('userId' in request.resource.data) || request.resource.data.userId == resource.data.userId;
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function validStringLength(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidNote(data) {
      let hasRequired = hasRequiredFields(['id', 'userId', 'title', 'content', 'isPinned', 'createdAt', 'updatedAt']);
      let validId = data.id is string && data.id.size() > 0 && data.id.size() <= 100;
      let validUserId = data.userId is string && data.userId.size() > 0 && data.userId.size() <= 100;
      let validTitle = data.title is string && data.title.size() <= 500;
      let validContent = data.content is string && data.content.size() <= 100000;
      let validIsPinned = data.isPinned is bool;
      let validCreatedAt = data.createdAt is timestamp;
      let validUpdatedAt = data.updatedAt is timestamp;
      let validDeadline = !('deadline' in data) || data.deadline == null || data.deadline is timestamp;
      
      return hasRequired && validId && validUserId && validTitle && validContent && validIsPinned && validCreatedAt && validUpdatedAt && validDeadline;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /notes/{noteId} {
      allow read: if isDocOwner();
      
      allow create: if isAuthenticated() && 
                    isValidNote(request.resource.data) && 
                    uidUnchanged() && 
                    request.resource.data.userId == request.auth.uid;
                    
      allow update: if isDocOwner() && 
                    isValidNote(request.resource.data) && 
                    uidNotModified() && 
                    request.resource.data.createdAt == resource.data.createdAt;
                    
      allow delete: if isDocOwner();
    }
  }
}
