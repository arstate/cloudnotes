{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A user's note.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the note."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns the note."
        },
        "title": {
          "type": "string",
          "description": "The title of the note."
        },
        "content": {
          "type": "string",
          "description": "The main content of the note."
        },
        "isPinned": {
          "type": "boolean",
          "description": "Whether the note is pinned."
        },
        "deadline": {
          "type": "string",
          "format": "date-time",
          "description": "Optional deadline for the note."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Creation timestamp."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp."
        }
      },
      "required": ["id", "userId", "title", "content", "isPinned", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": {
        "$ref": "#/entities/Note"
      },
      "description": "Collection of user notes."
    }
  }
}
